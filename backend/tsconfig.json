{
  "compilerOptions": {
    // ESM Configuration
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    
    // File Layout
    "rootDir": "./",
    "outDir": "./dist",
    
    // Type checking
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    
    // Other settings
    "sourceMap": true,
    "declaration": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    
    // Node.js types
    "types": ["node"],
    "lib": ["ES2022"]
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  }
}
